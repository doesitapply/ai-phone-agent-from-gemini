# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required: Your Google Gemini API key
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── Application ──────────────────────────────────────────────────────────────
# The public URL where this app is hosted (used for Twilio webhooks)
# For local dev, use ngrok: https://abc123.ngrok.io
# AI Studio automatically injects this at runtime with the Cloud Run service URL
APP_URL="https://your-app-url.example.com"

# Optional: Port to run the server on (default: 3000)
# PORT=3000

# Optional: API key to protect the dashboard endpoints
# If set, all /api/* requests (except Twilio webhooks) must include:
#   Header: X-Api-Key: <your_key>
# Leave unset for open access (fine for local dev, NOT for production)
# DASHBOARD_API_KEY="generate-a-strong-random-key-here"

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Required: Your Twilio credentials
# Get them at: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"

# Your Twilio phone number in E.164 format
# Get one at: https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_PHONE_NUMBER="+15551234567"

# ─── OpenClaw Gateway Integration ─────────────────────────────────────────────
# Optional: Wire OpenClaw as the AI brain for all phone calls.
# When enabled, calls are routed to your OpenClaw Gateway instead of Gemini.
# Gemini remains as automatic fallback if OpenClaw is unreachable.
#
# Prerequisites:
#   1. OpenClaw installed and running: npm install -g openclaw@latest
#   2. Gateway started: openclaw gateway --port 18789
#   3. OpenResponses endpoint enabled in openclaw.json:
#      { "gateway": { "http": { "endpoints": { "responses": { "enabled": true } } } } }
#
# Set to "true" to activate OpenClaw as the primary AI brain
# OPENCLAW_ENABLED="true"

# Your OpenClaw Gateway base URL (no trailing slash)
# For local dev: http://localhost:18789
# For remote: https://your-openclaw-host.example.com
# OPENCLAW_GATEWAY_URL="http://localhost:18789"

# Bearer token from your openclaw.json gateway.auth.token
# OPENCLAW_GATEWAY_TOKEN="your_openclaw_gateway_token"

# Agent ID to target (default: "main")
# Run `openclaw agent list` to see available agents
# OPENCLAW_AGENT_ID="main"

# Model string — leave blank to auto-derive from agent ID
# Examples: "openclaw:main", "openai-codex/gpt-5.3-codex"
# OPENCLAW_MODEL="openclaw:main"

# Request timeout in milliseconds (default: 10000)
# OPENCLAW_TIMEOUT_MS="10000"

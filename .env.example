# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required: Your Google Gemini API key
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── Application ──────────────────────────────────────────────────────────────
# The public URL where this app is hosted (used for Twilio webhooks)
# For local dev, use ngrok: https://abc123.ngrok.io
# AI Studio automatically injects this at runtime with the Cloud Run service URL
APP_URL="https://your-app-url.example.com"

# Optional: Port to run the server on (default: 3000)
# PORT=3000

# Optional: API key to protect the dashboard endpoints
# If set, all /api/* requests (except Twilio webhooks) must include:
#   Header: X-Api-Key: <your_key>
# Leave unset for open access (fine for local dev, NOT for production)
# DASHBOARD_API_KEY="generate-a-strong-random-key-here"

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Required: Your Twilio credentials
# Get them at: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"

# Your Twilio phone number in E.164 format
# Get one at: https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_PHONE_NUMBER="+15551234567"

{
  "name": "ai-phone-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file .env.local server.ts",
    "build": "vite build && node scripts/build-server.mjs",
    "build:frontend": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "start": "node dist-server/server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit",
    "check:auth": "node scripts/check-auth-regression.mjs .",
    "check:first-dollar-env": "node scripts/check-first-dollar-env.mjs",
    "check:launch-blockers": "bash scripts/check-launch-blockers.sh",
    "check:pricing": "node scripts/check-pricing-consistency.mjs",
    "check:resend-domain": "node scripts/check-resend-domain-readiness.mjs",
    "check:smirk-sender-dns": "node scripts/check-smirk-sender-dns.mjs",
    "check:railway:resend-domain": "node scripts/check-railway-resend-domain-readiness.mjs",
    "export:railway:resend-dns": "node scripts/export-railway-resend-dns.mjs",
    "check:stripe-attach": "bash scripts/check-stripe-attach.sh",
    "check:railway:first-dollar-env": "node scripts/check-railway-first-dollar-env.mjs",
    "smoke:buyer-auth": "bash scripts/buyer-funnel-auth-smoke.sh",
    "check:deploy-fingerprint": "node scripts/check-deploy-fingerprint.mjs",
    "check:deploy-fingerprint:current": "SMIRK_EXPECT_BRANCH=$(git branch --show-current) SMIRK_EXPECT_VERSION=$(git rev-parse HEAD) node scripts/check-deploy-fingerprint.mjs",
    "check:live-db-health": "node scripts/check-live-db-health.mjs",
    "check:railway-db-wiring": "node scripts/check-railway-db-wiring.mjs",
    "check:landing-live": "node scripts/check-landing-live-readiness.mjs",
    "check:operator-session-live": "node scripts/check-operator-session-live.mjs",
    "check:buyer-routes-live": "node scripts/check-live-buyer-routes.mjs",
    "check:secret-inventory": "node scripts/check-secret-inventory.mjs",
    "check:latest-failed-deploy": "node scripts/check-latest-failed-deploy.mjs",
    "check:live-deploy-readiness": "node scripts/check-live-deploy-readiness.mjs",
    "check:local-runtime-smoke": "node scripts/check-local-runtime-smoke.mjs",
    "check:live-app-critical-health": "node scripts/check-live-app-critical-health.mjs",
    "check:post-deploy-live": "npm run check:deploy-fingerprint && npm run check:google-auth-live && npm run check:buyer-routes-live && npm run check:live-db-health && npm run smoke:buyer-auth && npm run check:operator-session-live",
    "watchdog:health": "curl -sf ${APP_URL:-http://localhost:3000}/health | node -e \"const d=require('fs').readFileSync('/dev/stdin','utf8');const j=JSON.parse(d);console.log('Health:',j.status,'| uptime:',j.uptime,'| db:',j.db);process.exit(j.status==='ok'?0:1)\"",
    "openclaw:automate": "node scripts/fix-openclaw.mjs",
    "openclaw:check": "node scripts/fix-openclaw.mjs --dry-run",
    "check:railway": "bash scripts/check-railway-access.sh",
    "check:railway:healthcheck": "node scripts/check-railway-healthcheck.mjs",
    "check:google-auth-live": "node scripts/check-google-auth-live.mjs",
    "set:first-dollar-live-env": "bash scripts/set-first-dollar-live-env.sh",
    "set:landing-app-url": "bash scripts/set-landing-app-url.sh",
    "set:live-from-email": "bash scripts/set-live-from-email.sh",
    "cutover:sender-domain": "bash scripts/smirk-domain-cutover.sh",
    "load:railway-auth": "bash scripts/load-railway-auth.sh",
    "bootstrap:railway-auth": "bash scripts/bootstrap-railway-auth.sh",
    "set:operator-secret": "bash scripts/set-operator-secret.sh",
    "set:google-auth-env": "bash scripts/set-google-auth-env.sh",
    "print:google-auth-setup": "node scripts/print-google-auth-setup.mjs"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/genai": "^1.29.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.85",
    "@tailwindcss/vite": "^4.1.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "morgan": "^1.10.1",
    "motion": "^12.23.24",
    "openai": "^6.27.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.1",
    "twilio": "^5.12.2",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "protobufjs"
    ]
  }
}
